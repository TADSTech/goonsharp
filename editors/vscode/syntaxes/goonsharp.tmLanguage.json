{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GoonSharp",
  "scopeName": "source.goonsharp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#attributes" },
    { "include": "#macros" },
    { "include": "#goon-keywords" },
    { "include": "#control-keywords" },
    { "include": "#type-keywords" },
    { "include": "#boolean-keywords" },
    { "include": "#special-keywords" },
    { "include": "#operators" },
    { "include": "#easter-eggs" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#lifetimes" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.goonsharp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.goonsharp",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.goonsharp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.goonsharp",
              "match": "\\\\."
            },
            {
              "name": "variable.other.format.goonsharp",
              "match": "\\{[^}]*\\}"
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.goonsharp",
          "match": "'(\\\\.|[^'\\\\])'"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.goonsharp",
          "match": "#\\[([^\\]]*)\\]",
          "captures": {
            "1": { "name": "entity.other.attribute-name.goonsharp" }
          }
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.goonprint.goonsharp",
          "match": "\\b(goonprint|gooneprint|goonformat)!"
        },
        {
          "name": "entity.name.function.macro.ruin.goonsharp",
          "match": "\\b(ruin|post_nut_clarity)!"
        },
        {
          "name": "entity.name.function.macro.goonsharp",
          "match": "\\b(goonmacro|goonvec)!"
        },
        {
          "name": "entity.name.function.macro.rust.goonsharp",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*!"
        }
      ]
    },
    "goon-keywords": {
      "patterns": [
        {
          "name": "keyword.other.goonsesh.goonsharp",
          "match": "\\b(goonsesh)\\b"
        },
        {
          "name": "keyword.other.goon-binding.goonsharp",
          "match": "\\b(goon|goonconst)\\b"
        },
        {
          "name": "keyword.other.goon-visibility.goonsharp",
          "match": "\\b(goonpub)\\b"
        },
        {
          "name": "keyword.other.goon-module.goonsharp",
          "match": "\\b(goonmod|goonuse|gooncrate|goonsuper|goonextern)\\b"
        },
        {
          "name": "keyword.other.goon-type-def.goonsharp",
          "match": "\\b(goonstruct|goonenum|goonimpl|goontrait|goontype)\\b"
        },
        {
          "name": "keyword.other.goon-async.goonsharp",
          "match": "\\b(goonasync|goonawait)\\b"
        },
        {
          "name": "keyword.other.goon-modifier.goonsharp",
          "match": "\\b(goonmut|goonref|goonmove|goondyn|goonunsafe|goonstatic|goonconst2)\\b"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.goonsharp",
          "match": "\\b(goonif|goonelse|goonloop|goonfor|goonmatch|goonforever|edging)\\b"
        },
        {
          "name": "keyword.control.return.goonsharp",
          "match": "\\b(goonreturn)\\b"
        },
        {
          "name": "keyword.control.break.goonsharp",
          "match": "\\b(coom)\\b"
        },
        {
          "name": "keyword.control.continue.goonsharp",
          "match": "\\b(nutting)\\b"
        },
        {
          "name": "keyword.other.goonsharp",
          "match": "\\b(goonin|goonas|goonwhere|goonself|GoonSelf)\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "support.type.option.goonsharp",
          "match": "\\b(goonsome|goonnone|goonok|goonerr|GoonBox)\\b"
        }
      ]
    },
    "boolean-keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.goonsharp",
          "match": "\\b(gooning|edge)\\b"
        },
        {
          "name": "constant.language.boolean.false.goonsharp",
          "match": "\\b(no_goon|no_edge)\\b"
        }
      ]
    },
    "special-keywords": {
      "patterns": [
        {
          "name": "keyword.control.panic.goonsharp",
          "match": "\\b(ruin)\\b"
        },
        {
          "name": "keyword.control.debug.goonsharp",
          "match": "\\b(post_nut_clarity)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.goonsharp",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)"
        },
        {
          "name": "keyword.operator.comparison.goonsharp",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.goonsharp",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.goonsharp",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.goonsharp",
          "match": "(->|=>)"
        },
        {
          "name": "keyword.operator.range.goonsharp",
          "match": "(\\.\\.\\.|\\.\\.|\\.\\.=)"
        },
        {
          "name": "keyword.operator.path.goonsharp",
          "match": "::"
        },
        {
          "name": "keyword.operator.question.goonsharp",
          "match": "\\?"
        }
      ]
    },
    "easter-eggs": {
      "patterns": [
        {
          "name": "constant.numeric.nice.goonsharp",
          "match": "\\b69\\b"
        },
        {
          "name": "constant.numeric.blaze.goonsharp",
          "match": "\\b420\\b"
        },
        {
          "name": "constant.numeric.leet.goonsharp",
          "match": "\\b1337\\b"
        },
        {
          "name": "constant.numeric.goated.goonsharp",
          "match": "\\b(6969|42069|80085|8008135)\\b"
        },
        {
          "name": "keyword.easter.gooner.goonsharp",
          "match": "\\b(gooner|gooners|gooning_hard)\\b"
        },
        {
          "name": "keyword.easter.bruh.goonsharp",
          "match": "\\b(bruh|ayo|sheesh|bussin|nocap|frfr|ong)\\b"
        },
        {
          "name": "keyword.easter.sigma.goonsharp",
          "match": "\\b(sigma|alpha|chad|based|rizz|gyatt|ohio|skibidi|fanum_tax)\\b"
        },
        {
          "name": "keyword.easter.gaming.goonsharp",
          "match": "\\b(gg|ez|ratio|cope|seethe|mald|kekw)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.goonsharp",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.hex.goonsharp",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.goonsharp",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.goonsharp",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.goonsharp",
          "match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize)?\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.goonsharp",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.goonsharp",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "storage.type.primitive.goonsharp",
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|str)\\b"
        }
      ]
    },
    "lifetimes": {
      "patterns": [
        {
          "name": "storage.modifier.lifetime.goonsharp",
          "match": "'[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.goonsharp",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
