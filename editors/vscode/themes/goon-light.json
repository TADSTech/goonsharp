{
  "name": "GoonLight",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#fdf6ff",
    "editor.foreground": "#1a0a2e",
    "activityBar.background": "#f0e0ff",
    "activityBar.foreground": "#9b00e6",
    "activityBar.activeBorder": "#9b00e6",
    "sideBar.background": "#f5eaff",
    "sideBar.foreground": "#2d1050",
    "sideBarTitle.foreground": "#9b00e6",
    "titleBar.activeBackground": "#f0e0ff",
    "titleBar.activeForeground": "#9b00e6",
    "statusBar.background": "#9b00e6",
    "statusBar.foreground": "#ffffff",
    "statusBar.debuggingBackground": "#e65100",
    "statusBar.noFolderBackground": "#7c4dff",
    "tab.activeBackground": "#fdf6ff",
    "tab.activeForeground": "#9b00e6",
    "tab.activeBorderTop": "#9b00e6",
    "tab.inactiveBackground": "#f0e0ff",
    "tab.inactiveForeground": "#8e6aad",
    "tab.hoverBackground": "#ead0ff",
    "editorLineNumber.foreground": "#c9a0e8",
    "editorLineNumber.activeForeground": "#9b00e6",
    "editorCursor.foreground": "#d500f9",
    "editor.selectionBackground": "#d500f930",
    "editor.selectionHighlightBackground": "#9b00e615",
    "editor.lineHighlightBackground": "#f5eaff",
    "editor.lineHighlightBorder": "#ead0ff",
    "editor.findMatchBackground": "#ffcc0060",
    "editor.findMatchHighlightBackground": "#d500f920",
    "editorBracketMatch.background": "#d500f920",
    "editorBracketMatch.border": "#d500f980",
    "editorIndentGuide.activeBackground1": "#9b00e640",
    "editorIndentGuide.background1": "#e0c8f030",
    "focusBorder": "#9b00e660",
    "terminal.background": "#fdf6ff",
    "terminal.foreground": "#1a0a2e",
    "terminal.ansiMagenta": "#d500f9",
    "terminal.ansiBrightMagenta": "#9b00e6",
    "terminal.ansiRed": "#c62828",
    "terminal.ansiGreen": "#00803a",
    "terminal.ansiYellow": "#bf8600",
    "terminal.ansiBlue": "#0055cc",
    "terminal.ansiCyan": "#007a7a",
    "terminal.ansiWhite": "#1a0a2e",
    "badge.background": "#9b00e6",
    "badge.foreground": "#ffffff",
    "list.activeSelectionBackground": "#d500f920",
    "list.activeSelectionForeground": "#9b00e6",
    "list.hoverBackground": "#f0e0ff",
    "list.highlightForeground": "#007a7a",
    "button.background": "#9b00e6",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#7b00b5",
    "input.background": "#ffffff",
    "input.border": "#d0b0ee",
    "input.foreground": "#1a0a2e",
    "input.placeholderForeground": "#8e6aad",
    "dropdown.background": "#ffffff",
    "dropdown.border": "#d0b0ee",
    "scrollbarSlider.background": "#9b00e620",
    "scrollbarSlider.hoverBackground": "#9b00e640",
    "scrollbarSlider.activeBackground": "#9b00e660",
    "minimap.background": "#fdf6ff",
    "editorOverviewRuler.border": "#ead0ff",
    "panel.background": "#fdf6ff",
    "panel.border": "#ead0ff",
    "panelTitle.activeForeground": "#9b00e6",
    "panelTitle.activeBorder": "#9b00e6",
    "gitDecoration.modifiedResourceForeground": "#bf8600",
    "gitDecoration.untrackedResourceForeground": "#00803a",
    "gitDecoration.deletedResourceForeground": "#c62828",
    "editorError.foreground": "#c62828",
    "editorWarning.foreground": "#bf8600",
    "editorInfo.foreground": "#0055cc"
  },
  "tokenColors": [
    {
      "name": "Comments — lavender whisper",
      "scope": ["comment", "comment.line", "comment.block"],
      "settings": {
        "foreground": "#b388d9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — deep emerald",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#00803a"
      }
    },
    {
      "name": "String escapes — teal punch",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#007a7a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String interpolation — burnt amber",
      "scope": ["variable.other.format"],
      "settings": {
        "foreground": "#bf8600",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers — blazing orange",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e65100"
      }
    },
    {
      "name": "Booleans — hot violet bold",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#aa00ff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "goonsesh keyword — SCREAMING PURPLE",
      "scope": ["keyword.other.goonsesh"],
      "settings": {
        "foreground": "#9b00e6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Binding keywords — vivid purple",
      "scope": ["keyword.other.goon-binding"],
      "settings": {
        "foreground": "#9b00e6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Visibility — plum italic",
      "scope": ["keyword.other.goon-visibility"],
      "settings": {
        "foreground": "#8e24aa",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Module keywords — deep indigo",
      "scope": ["keyword.other.goon-module"],
      "settings": {
        "foreground": "#4a148c"
      }
    },
    {
      "name": "Type def keywords — vivid purple bold underline",
      "scope": ["keyword.other.goon-type-def"],
      "settings": {
        "foreground": "#9b00e6",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Async keywords — teal bold italic",
      "scope": ["keyword.other.goon-async"],
      "settings": {
        "foreground": "#007a7a",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Modifiers — muted grape",
      "scope": ["keyword.other.goon-modifier"],
      "settings": {
        "foreground": "#7c4dff"
      }
    },
    {
      "name": "Control flow — vivid purple",
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#9b00e6"
      }
    },
    {
      "name": "Return — orchid italic",
      "scope": ["keyword.control.return"],
      "settings": {
        "foreground": "#aa00ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Break — crimson bold",
      "scope": ["keyword.control.break"],
      "settings": {
        "foreground": "#c62828",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Continue — amber",
      "scope": ["keyword.control.continue"],
      "settings": {
        "foreground": "#bf8600"
      }
    },
    {
      "name": "Panic — BLOOD RED UNDERLINE",
      "scope": ["keyword.control.panic"],
      "settings": {
        "foreground": "#b71c1c",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Debug — amber italic",
      "scope": ["keyword.control.debug"],
      "settings": {
        "foreground": "#bf8600",
        "fontStyle": "italic"
      }
    },
    {
      "name": "goonprint macro — deep purple",
      "scope": ["entity.name.function.macro.goonprint"],
      "settings": {
        "foreground": "#7c4dff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "ruin macro — blood red",
      "scope": ["entity.name.function.macro.ruin"],
      "settings": {
        "foreground": "#b71c1c",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Other macros — indigo",
      "scope": ["entity.name.function.macro"],
      "settings": {
        "foreground": "#4a148c"
      }
    },
    {
      "name": "Functions — royal blue",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#0055cc"
      }
    },
    {
      "name": "Types — burnt orange bold",
      "scope": ["entity.name.type"],
      "settings": {
        "foreground": "#e65100",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Primitive types — rose",
      "scope": ["storage.type.primitive"],
      "settings": {
        "foreground": "#c2185b"
      }
    },
    {
      "name": "Option/Result types — teal bold",
      "scope": ["support.type.option"],
      "settings": {
        "foreground": "#007a7a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Lifetimes — gold italic",
      "scope": ["storage.modifier.lifetime"],
      "settings": {
        "foreground": "#bf8600",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators — slate purple",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#6a4c93"
      }
    },
    {
      "name": "Arrow operator — vivid purple",
      "scope": ["keyword.operator.arrow"],
      "settings": {
        "foreground": "#9b00e6"
      }
    },
    {
      "name": "Attributes — grape italic",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#7c4dff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables — deep ink",
      "scope": ["variable.other"],
      "settings": {
        "foreground": "#1a0a2e"
      }
    },
    {
      "name": "Parameters — cobalt italic",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#1565c0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation — muted grape",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#8e6aad"
      }
    },
    {
      "name": "Brackets — darker grape",
      "scope": ["punctuation.bracket", "punctuation.section"],
      "settings": {
        "foreground": "#6a4c93"
      }
    },
    {
      "name": "Self — purple italic",
      "scope": ["variable.language.self", "variable.language.this"],
      "settings": {
        "foreground": "#9b00e6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants — burnt amber bold",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": {
        "foreground": "#bf8600",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespace/module — deep indigo",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#4a148c"
      }
    },
    {
      "name": "Trait names — teal bold",
      "scope": ["entity.name.type.trait", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#007a7a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Enum members — orange italic",
      "scope": ["variable.other.enummember", "constant.other.enum"],
      "settings": {
        "foreground": "#e65100",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Macro bang — purple",
      "scope": ["punctuation.definition.macro"],
      "settings": {
        "foreground": "#7c4dff"
      }
    },
    {
      "name": "69 — nice (hot pink bold italic)",
      "scope": ["constant.numeric.nice"],
      "settings": {
        "foreground": "#d81b60",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "420 — blaze it green",
      "scope": ["constant.numeric.blaze"],
      "settings": {
        "foreground": "#2e7d32",
        "fontStyle": "bold"
      }
    },
    {
      "name": "1337 — hacker green bold italic",
      "scope": ["constant.numeric.leet"],
      "settings": {
        "foreground": "#1b5e20",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Goated numbers — golden legendary",
      "scope": ["constant.numeric.goated"],
      "settings": {
        "foreground": "#f9a825",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Gooner words — throbbing magenta",
      "scope": ["keyword.easter.gooner"],
      "settings": {
        "foreground": "#d500f9",
        "fontStyle": "bold italic underline"
      }
    },
    {
      "name": "Bruh/slang — chaotic lime",
      "scope": ["keyword.easter.bruh"],
      "settings": {
        "foreground": "#558b2f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Sigma/brainrot — deep teal italic",
      "scope": ["keyword.easter.sigma"],
      "settings": {
        "foreground": "#00695c",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Gaming words — rage red",
      "scope": ["keyword.easter.gaming"],
      "settings": {
        "foreground": "#c62828",
        "fontStyle": "bold"
      }
    }
  ]
}
