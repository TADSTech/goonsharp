{
  "name": "DarkGoon",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080510",
    "editor.foreground": "#e0d4ff",
    "activityBar.background": "#0a0616",
    "activityBar.foreground": "#ff2edc",
    "activityBar.activeBorder": "#ff2edc",
    "sideBar.background": "#0c0818",
    "sideBar.foreground": "#c9b8f0",
    "sideBarTitle.foreground": "#ff2edc",
    "titleBar.activeBackground": "#0c0818",
    "titleBar.activeForeground": "#ff2edc",
    "statusBar.background": "#ff2edc",
    "statusBar.foreground": "#080510",
    "statusBar.debuggingBackground": "#ff6b00",
    "statusBar.noFolderBackground": "#4400aa",
    "tab.activeBackground": "#150d28",
    "tab.activeForeground": "#ff2edc",
    "tab.activeBorderTop": "#ff2edc",
    "tab.inactiveBackground": "#0a0616",
    "tab.inactiveForeground": "#6b5a8e",
    "tab.hoverBackground": "#1f1340",
    "editorLineNumber.foreground": "#3a1e6d",
    "editorLineNumber.activeForeground": "#ff2edc",
    "editorCursor.foreground": "#00ffcc",
    "editorCursor.background": "#080510",
    "editor.selectionBackground": "#ff2edc30",
    "editor.selectionHighlightBackground": "#00ffcc15",
    "editor.lineHighlightBackground": "#0f0920",
    "editor.lineHighlightBorder": "#1a0e35",
    "editor.findMatchBackground": "#ff6b0050",
    "editor.findMatchHighlightBackground": "#ff2edc25",
    "editorBracketMatch.background": "#ff2edc20",
    "editorBracketMatch.border": "#ff2edc80",
    "editorIndentGuide.activeBackground1": "#ff2edc40",
    "editorIndentGuide.background1": "#1a0e3530",
    "focusBorder": "#ff2edc60",
    "terminal.background": "#080510",
    "terminal.foreground": "#e0d4ff",
    "terminal.ansiMagenta": "#ff2edc",
    "terminal.ansiBrightMagenta": "#ff79f2",
    "terminal.ansiRed": "#ff3366",
    "terminal.ansiGreen": "#00ff88",
    "terminal.ansiYellow": "#ffdd00",
    "terminal.ansiBlue": "#00aaff",
    "terminal.ansiCyan": "#00ffcc",
    "terminal.ansiWhite": "#e0d4ff",
    "badge.background": "#ff2edc",
    "badge.foreground": "#080510",
    "list.activeSelectionBackground": "#ff2edc30",
    "list.activeSelectionForeground": "#ff2edc",
    "list.hoverBackground": "#150d28",
    "list.highlightForeground": "#00ffcc",
    "button.background": "#ff2edc",
    "button.foreground": "#080510",
    "button.hoverBackground": "#ff79f2",
    "input.background": "#0c0818",
    "input.border": "#ff2edc40",
    "input.foreground": "#e0d4ff",
    "input.placeholderForeground": "#6b5a8e",
    "dropdown.background": "#0c0818",
    "dropdown.border": "#ff2edc40",
    "scrollbarSlider.background": "#ff2edc20",
    "scrollbarSlider.hoverBackground": "#ff2edc40",
    "scrollbarSlider.activeBackground": "#ff2edc60",
    "minimap.background": "#080510",
    "editorOverviewRuler.border": "#1a0e35",
    "panel.background": "#080510",
    "panel.border": "#1a0e35",
    "panelTitle.activeForeground": "#ff2edc",
    "panelTitle.activeBorder": "#ff2edc",
    "gitDecoration.modifiedResourceForeground": "#ffdd00",
    "gitDecoration.untrackedResourceForeground": "#00ff88",
    "gitDecoration.deletedResourceForeground": "#ff3366",
    "editorError.foreground": "#ff3366",
    "editorWarning.foreground": "#ffdd00",
    "editorInfo.foreground": "#00aaff"
  },
  "tokenColors": [
    {
      "name": "Comments — ghostly whispers",
      "scope": ["comment", "comment.line", "comment.block"],
      "settings": {
        "foreground": "#5c3d8f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — radioactive green",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#00ff88"
      }
    },
    {
      "name": "String escapes — electric cyan",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#00ffcc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String interpolation — molten gold",
      "scope": ["variable.other.format"],
      "settings": {
        "foreground": "#ffdd00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers — hot orange",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ff6b00"
      }
    },
    {
      "name": "Booleans — plasma pink bold",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#ff79f2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "goonsesh keyword — NEON PINK SCREAMING",
      "scope": ["keyword.other.goonsesh"],
      "settings": {
        "foreground": "#ff2edc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Binding keywords (sesh, goontag, etc) — hot magenta",
      "scope": ["keyword.other.goon-binding"],
      "settings": {
        "foreground": "#ff2edc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Visibility — soft violet italic",
      "scope": ["keyword.other.goon-visibility"],
      "settings": {
        "foreground": "#bb86fc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Module keywords — ultraviolet",
      "scope": ["keyword.other.goon-module"],
      "settings": {
        "foreground": "#9d4edd"
      }
    },
    {
      "name": "Type def keywords (gang, regime, etc) — blazing magenta bold",
      "scope": ["keyword.other.goon-type-def"],
      "settings": {
        "foreground": "#ff2edc",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Async keywords — holographic cyan italic",
      "scope": ["keyword.other.goon-async"],
      "settings": {
        "foreground": "#00ffcc",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Modifiers — deep lavender",
      "scope": ["keyword.other.goon-modifier"],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Control flow — neon pink",
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#ff2edc"
      }
    },
    {
      "name": "Return — hot pink underline",
      "scope": ["keyword.control.return"],
      "settings": {
        "foreground": "#ff79f2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Break — danger red bold",
      "scope": ["keyword.control.break"],
      "settings": {
        "foreground": "#ff3366",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Continue — warning gold",
      "scope": ["keyword.control.continue"],
      "settings": {
        "foreground": "#ffdd00"
      }
    },
    {
      "name": "Panic — ALARM RED UNDERLINE",
      "scope": ["keyword.control.panic"],
      "settings": {
        "foreground": "#ff0040",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Debug — amber italic",
      "scope": ["keyword.control.debug"],
      "settings": {
        "foreground": "#ffdd00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "goonprint macro — purple glow",
      "scope": ["entity.name.function.macro.goonprint"],
      "settings": {
        "foreground": "#bb86fc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "ruin macro — violent red",
      "scope": ["entity.name.function.macro.ruin"],
      "settings": {
        "foreground": "#ff0040",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Other macros — electric indigo",
      "scope": ["entity.name.function.macro"],
      "settings": {
        "foreground": "#7c4dff"
      }
    },
    {
      "name": "Functions — electric blue",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#00aaff"
      }
    },
    {
      "name": "Types — molten orange",
      "scope": ["entity.name.type"],
      "settings": {
        "foreground": "#ff6b00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Primitive types — coral pink",
      "scope": ["storage.type.primitive"],
      "settings": {
        "foreground": "#ff5277"
      }
    },
    {
      "name": "Option/Result types — holographic cyan",
      "scope": ["support.type.option"],
      "settings": {
        "foreground": "#00ffcc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Lifetimes — golden italic",
      "scope": ["storage.modifier.lifetime"],
      "settings": {
        "foreground": "#ffdd00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators — muted lavender",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#8e7ab5"
      }
    },
    {
      "name": "Arrow operator — neon pink",
      "scope": ["keyword.operator.arrow"],
      "settings": {
        "foreground": "#ff2edc"
      }
    },
    {
      "name": "Attributes — violet italic",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#b388ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables — soft off-white lavender",
      "scope": ["variable.other"],
      "settings": {
        "foreground": "#e0d4ff"
      }
    },
    {
      "name": "Parameters — icy blue",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#80d4ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation — dim purple",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#6b5a8e"
      }
    },
    {
      "name": "Brackets — slightly brighter purple",
      "scope": ["punctuation.bracket", "punctuation.section"],
      "settings": {
        "foreground": "#8e7ab5"
      }
    },
    {
      "name": "Self/this — neon pink italic",
      "scope": ["variable.language.self", "variable.language.this"],
      "settings": {
        "foreground": "#ff2edc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants — bright gold bold",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": {
        "foreground": "#ffdd00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Namespace/module — ultraviolet",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#9d4edd"
      }
    },
    {
      "name": "Trait names — cyan bold",
      "scope": ["entity.name.type.trait", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#00ffcc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Enum members — orange italic",
      "scope": ["variable.other.enummember", "constant.other.enum"],
      "settings": {
        "foreground": "#ff6b00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Macro bang — violet",
      "scope": ["punctuation.definition.macro"],
      "settings": {
        "foreground": "#bb86fc"
      }
    },
    {
      "name": "69 — nice (rainbow gradient effect via pink)",
      "scope": ["constant.numeric.nice"],
      "settings": {
        "foreground": "#ff69b4",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "420 — blaze it green",
      "scope": ["constant.numeric.blaze"],
      "settings": {
        "foreground": "#39ff14",
        "fontStyle": "bold"
      }
    },
    {
      "name": "1337 — hacker green on black",
      "scope": ["constant.numeric.leet"],
      "settings": {
        "foreground": "#00ff41",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Goated numbers — golden legendary",
      "scope": ["constant.numeric.goated"],
      "settings": {
        "foreground": "#ffd700",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Gooner words — throbbing magenta",
      "scope": ["keyword.easter.gooner"],
      "settings": {
        "foreground": "#ff2edc",
        "fontStyle": "bold italic underline"
      }
    },
    {
      "name": "Bruh/slang — chaotic lime",
      "scope": ["keyword.easter.bruh"],
      "settings": {
        "foreground": "#adff2f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Sigma/brainrot — glowing cyan italic",
      "scope": ["keyword.easter.sigma"],
      "settings": {
        "foreground": "#00ffff",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Gaming words — rage red",
      "scope": ["keyword.easter.gaming"],
      "settings": {
        "foreground": "#ff4444",
        "fontStyle": "bold"
      }
    }
  ]
}
